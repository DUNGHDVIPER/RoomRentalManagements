@page
@model WebHostRazor.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Login - Room Rental Management</title>
    <link rel="stylesheet" href="~/css/theme.css" />
    <style>
        .success-message {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 16px;
            animation: slideDown 0.3s ease-out;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .success-icon {
            color: #28a745;
            margin-right: 8px;
        }

        .google-btn {
            background: #4285f4;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background-color 0.3s ease;
        }

            .google-btn:hover {
                background: #357ae8;
            }

        .divider {
            display: flex;
            align-items: center;
            margin: 16px 0;
            color: #666;
            font-size: 13px;
        }

            .divider::before,
            .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #ddd;
            }

            .divider span {
                padding: 0 12px;
            }
    </style>
</head>
<body class="bg-grad">
    <div class="shell" style="justify-content:center;align-items:center;">
        <div class="card p-18" style="width:min(520px,calc(100vw - 32px));">
            <div style="display:flex;gap:12px;align-items:center;">
                <div class="brand-logo">H</div>
                <div>
                    <div style="font-weight:950;font-size:18px;">Host Portal Login</div>
                    <div class="muted">Host: <b>host@demo.com</b> / <b>Host@12345!</b></div>
                    <div class="muted">Admin: <b>admin@demo.com</b> / <b>Admin@12345!</b></div>
                </div>
            </div>

            <hr class="hr" />

            <!-- Success message từ Register -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="success-message">
                    <i class="success-icon">✓</i>
                    @TempData["SuccessMessage"]
                </div>
            }

            <!-- GOOGLE LOGIN BUTTON -->
            <form method="post" asp-page-handler="ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@Model.ReturnUrl">
                @Html.AntiForgeryToken()
                <button type="submit" class="google-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>
                    Continue with Google
                </button>
            </form>

            <div class="divider">
                <span>or</span>
            </div>

            <form method="post" style="display:grid;gap:12px;">
                @Html.AntiForgeryToken()
                <input name="ReturnUrl" type="hidden" value="@(Model.ReturnUrl ?? "")" />

                <input class="input" asp-for="Email" placeholder="Email"
                       value="@TempData["UserEmail"]" />
                <span asp-validation-for="Email" class="text-danger"></span>

                <input class="input" asp-for="Password" type="password" placeholder="Password" />
                <span asp-validation-for="Password" class="text-danger"></span>

                <div style="display:flex;justify-content:space-between;align-items:center;">
                    <label style="display:flex;gap:6px;align-items:center;font-size:13px;">
                        <input asp-for="RememberMe" type="checkbox" />
                        Remember me
                    </label>
                    <a href="/Auth/ForgotPassword" class="link" style="font-size:13px;">Forgot password?</a>
                </div>

                <button class="btn-grad" type="submit">Login</button>

                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="badge danger" style="padding:12px;border-radius:16px;">@Model.Error</div>
                }
            </form>

            <hr class="hr" />

            <div style="text-align:center;">
                <span class="muted">New to our platform?</span>
                <a href="/Auth/Register" class="link">Create Host Account</a>
            </div>
        </div>
    </div>
</body>
</html>