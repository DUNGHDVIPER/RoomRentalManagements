@page "{id:int}"
@model WebHostRazor.Pages.Host.Contracts.DetailsModel
@{
    ViewData["Title"] = "Contract Details";
}

<div class="contract-page">
    <partial name="/Pages/Host/Shared/_ToastPopup.cshtml" />

    @if (Model.Contract == null)
    {
        <div class="alert alert-warning rounded-4">Contract not found.</div>
    }
    else
    {
        <div class="contract-hero">
            <div>
                <div class="contract-breadcrumb">Host / Contracts / Details</div>
                <h1>Contract #@Model.Contract.Id</h1>
                <p>View contract details, deposit, history, and attachments.</p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-soft" asp-page="./Index">Back</a>
                <a class="btn btn-soft" asp-page="./Renew" asp-route-id="@Model.Contract.Id">Renew</a>
                <a class="btn btn-soft" asp-page="./Terminate" asp-route-id="@Model.Contract.Id">Terminate</a>
                <a class="btn btn-soft" asp-page="./UploadAttachment" asp-route-id="@Model.Contract.Id">Upload</a>
                <a class="btn btn-soft" asp-page="./Versions" asp-route-id="@Model.Contract.Id">History</a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="contract-card h-100">
                    <div class="contract-section-title">Contract Information</div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-muted small">Room ID</div>
                            <div class="fw-semibold">@Model.Contract.RoomId</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Tenant ID</div>
                            <div class="fw-semibold">@Model.Contract.TenantId</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Start Date</div>
                            <div class="fw-semibold">@Model.Contract.StartDate.ToString("yyyy-MM-dd")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">End Date</div>
                            <div class="fw-semibold">@Model.Contract.EndDate.ToString("yyyy-MM-dd")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Rent</div>
                            <div class="fw-semibold">@Model.Contract.Rent.ToString("n0") đ</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Deposit</div>
                            <div class="fw-semibold">@Model.Contract.Deposit.ToString("n0") đ</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Contract Code</div>
                            <div class="fw-semibold">@Model.Contract.ContractCode</div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small">Status</div>
                            <div>
                                @if (Model.Contract.IsActive)
                                {
                                    <span class="contract-badge active">Active</span>
                                }
                                else
                                {
                                    <span class="contract-badge">@Model.Contract.Status</span>
                                }
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <form method="post" asp-page-handler="Activate" asp-route-id="@Model.Contract.Id" class="d-flex flex-wrap gap-2">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-gradient-primary" type="submit">Activate Contract</button>
                        <a class="btn btn-soft" asp-page="./ExportPdf" asp-route-id="@Model.Contract.Id">Export PDF</a>
                    </form>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="contract-card mb-4">
                    <div class="contract-section-title">Deposit Status</div>

                    <div class="mb-2">
                        <div class="text-muted small">Status</div>
                        <div class="fw-semibold">@Model.Contract.DepositStatus</div>
                    </div>

                    <div class="mb-2">
                        <div class="text-muted small">Paid At</div>
                        <div class="fw-semibold">@Model.Contract.DepositPaidAt?.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>

                    <div>
                        <div class="text-muted small">Paid Amount</div>
                        <div class="fw-semibold">@Model.Contract.DepositPaidAmount?.ToString("n0") đ</div>
                    </div>
                </div>

                <div class="contract-card">
                    <div class="contract-section-title">Attachments</div>

                    @if (Model.Attachments == null || !Model.Attachments.Any())
                    {
                        <div class="text-muted">No attachments yet.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var a in Model.Attachments)
                            {
                                var url = a.Url ?? "";
                                var lower = url.ToLowerInvariant();
                                var isImg = lower.EndsWith(".jpg") || lower.EndsWith(".jpeg") || lower.EndsWith(".png");

                                <div class="border rounded-4 p-3">
                                    <div class="fw-semibold">
                                        <a href="@url" target="_blank">@a.FileName</a>
                                    </div>
                                    <div class="text-muted small mb-2">@a.UploadedAt.ToString("yyyy-MM-dd HH:mm")</div>

                                    @if (isImg)
                                    {
                                        <img src="@url" class="img-fluid rounded-3 border" />
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="col-12">
                <div class="contract-card">
                    <div class="contract-section-title">Deposit Management</div>

                    <div class="row g-4">
                        <div class="col-lg-6">
                            <div class="border rounded-4 p-4 h-100">
                                <h6 class="fw-semibold mb-3">Update Deposit Amount</h6>
                                <form method="post" asp-page-handler="UpdateDepositAmount" asp-route-id="@Model.Contract.Id" class="contract-form">
                                    @Html.AntiForgeryToken()

                                    <div class="mb-3">
                                        <label class="form-label">New Deposit Amount</label>
                                        <input class="form-control" type="number" step="0.01" asp-for="DepositAmountForm.NewDeposit" />
                                    </div>

                                    <button class="btn btn-gradient-primary" type="submit">Update Amount</button>
                                </form>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="border rounded-4 p-4 h-100">
                                <h6 class="fw-semibold mb-3">Update Deposit Status</h6>
                                <form method="post" asp-page-handler="UpdateDepositStatus" asp-route-id="@Model.Contract.Id" class="contract-form">
                                    @Html.AntiForgeryToken()

                                    <div class="mb-3">
                                        <label class="form-label">Required Deposit Amount</label>
                                        <input class="form-control" type="number" step="0.01" asp-for="DepositStatusForm.DepositAmount" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Deposit Status</label>
                                        <select class="form-select" asp-for="DepositStatusForm.DepositStatus">
                                            <option value="Unpaid">Unpaid</option>
                                            <option value="Paid">Paid</option>
                                            <option value="Refunded">Refunded</option>
                                            <option value="Forfeit">Forfeit</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Paid Amount</label>
                                        <input class="form-control" type="number" step="0.01" asp-for="DepositStatusForm.PaidAmount" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Paid At</label>
                                        <input class="form-control" type="datetime-local" asp-for="DepositStatusForm.PaidAt" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Note</label>
                                        <input class="form-control" asp-for="DepositStatusForm.Note" />
                                    </div>

                                    <button class="btn btn-gradient-primary" type="submit">Update Status</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>