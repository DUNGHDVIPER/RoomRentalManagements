@page
@model WebHostRazor.Pages.Host.Contracts.TerminateModel
@{
    ViewData["Title"] = "Terminate Contract";
}

<div class="contract-page">
    <partial name="/Pages/Host/Shared/_ToastPopup.cshtml" />

    <div class="contract-hero">
        <div>
            <div class="contract-breadcrumb">Host / Contracts / Terminate</div>
            <h1>Terminate Contract</h1>
            <p>Close the contract before its original end date.</p>
        </div>

        <a class="btn btn-soft" asp-page="./Details" asp-route-id="@Model.Vm.ContractId">Back</a>
    </div>

    <div class="contract-card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger rounded-3 mb-4">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form method="post" class="contract-form">
            <input type="hidden" asp-for="Vm.ContractId" />

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="Vm.TerminateDate" class="form-label fw-semibold"></label>
                    <input asp-for="Vm.TerminateDate" type="date" class="form-control" />
                    <span asp-validation-for="Vm.TerminateDate" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Vm.Reason" class="form-label fw-semibold"></label>
                    <textarea asp-for="Vm.Reason" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Vm.Reason" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <button class="btn btn-gradient-danger" type="submit">Terminate Contract</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="/Pages/Host/Shared/_ValidationScriptsPartial.cshtml" />
}