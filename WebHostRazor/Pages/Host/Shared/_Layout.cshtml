@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Host Portal</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/host-contracts.css" />

    <style>
        :root {
            --host-primary: #4f46e5;
            --host-primary-2: #7c3aed;
            --host-accent: #06b6d4;
            --host-text: #0f172a;
            --host-soft: #64748b;
            --host-border: rgba(148,163,184,.20);
            --host-card: rgba(255,255,255,.78);
            --host-shadow: 0 12px 32px rgba(15,23,42,.08);
        }

        html, body {
            min-height: 100%;
        }

        body {
            margin: 0;
            color: var(--host-text);
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: radial-gradient(circle at top left, rgba(99,102,241,.12), transparent 28%), radial-gradient(circle at top right, rgba(6,182,212,.10), transparent 24%), linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
        }

        .host-topbar {
            position: sticky;
            top: 0;
            z-index: 1030;
            backdrop-filter: blur(14px);
            background: rgba(255,255,255,.72);
            border-bottom: 1px solid var(--host-border);
            box-shadow: 0 4px 24px rgba(15,23,42,.04);
        }

        .host-navbar {
            min-height: 78px;
        }

        .host-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
        }

        .host-brand-badge {
            width: 46px;
            height: 46px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 800;
            font-size: 18px;
            background: linear-gradient(135deg, var(--host-primary), #8b5cf6, #34d399);
            box-shadow: 0 10px 22px rgba(79,70,229,.22);
        }

        .host-brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .host-brand-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--host-text);
        }

        .host-brand-sub {
            font-size: 12px;
            color: var(--host-soft);
            font-weight: 600;
        }

        .navbar-nav .nav-link {
            color: var(--host-text) !important;
            font-weight: 600;
            border-radius: 999px;
            padding: 10px 16px !important;
            transition: .2s ease;
        }

            .navbar-nav .nav-link:hover {
                background: rgba(79,70,229,.08);
                color: var(--host-primary) !important;
            }

        .host-admin-link {
            background: linear-gradient(135deg, var(--host-primary), var(--host-primary-2));
            color: #fff !important;
            box-shadow: 0 10px 22px rgba(79,70,229,.22);
        }

            .host-admin-link:hover {
                color: #fff !important;
                transform: translateY(-1px);
                background: linear-gradient(135deg, #4338ca, #6d28d9);
            }

        .host-auth-btn {
            border: 1px solid rgba(79,70,229,.16);
            background: rgba(255,255,255,.82);
        }

            .host-auth-btn:hover {
                border-color: rgba(79,70,229,.28);
                background: #fff;
            }

        .host-main-wrap {
            max-width: 1320px;
            margin: 28px auto;
            padding: 0 18px;
        }

        .host-content-shell {
            background: rgba(255,255,255,.38);
            border: 1px solid rgba(255,255,255,.35);
            border-radius: 28px;
            box-shadow: var(--host-shadow);
            backdrop-filter: blur(10px);
            overflow: hidden;
        }

        .host-main-content {
            padding: 28px;
        }

        .host-footer {
            margin-top: 28px;
            padding: 20px 0 34px;
            color: var(--host-soft);
            font-size: 14px;
        }

        .host-footer-card {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 18px;
        }

        .host-footer-inner {
            background: rgba(255,255,255,.62);
            border: 1px solid var(--host-border);
            border-radius: 20px;
            padding: 16px 20px;
            box-shadow: var(--host-shadow);
        }

        .btn-link.nav-link {
            text-decoration: none;
        }

        @@media (max-width: 991px) {
            .host-main-content {
                padding: 18px;
            }

            .host-navbar {
                min-height: auto;
                padding-top: 10px;
                padding-bottom: 10px;
            }
        }
    </style>
</head>

<body>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <header class="host-topbar">
        <nav class="navbar navbar-expand-lg navbar-light host-navbar">
            <div class="container-fluid px-4">
                <a class="host-brand" asp-area="" asp-page="/Index">
                    <div class="host-brand-badge">H</div>
                    <div class="host-brand-text">
                        <span class="host-brand-title">HostPortal</span>
                        <span class="host-brand-sub">Operate • Rooms • Billing</span>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#hostNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="hostNavbar">
                    <ul class="navbar-nav me-auto ms-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var user = await UserManager.GetUserAsync(User);
                            var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();

                            @if (roles.Contains("Admin") || roles.Contains("SuperAdmin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link host-admin-link" href="@Configuration["AdminUrl"]/Auth/Login" target="_blank">
                                        🔧 Admin Panel
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link host-auth-btn" asp-area="" asp-page="/Host/Profile/Index">Profile</a>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-area="" asp-page="/Auth/Logout" class="d-inline">
                                    <button type="submit" class="nav-link btn btn-link host-auth-btn px-3">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link host-auth-btn" asp-area="" asp-page="/Auth/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link host-admin-link" asp-area="" asp-page="/Auth/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="host-main-wrap">
        <div class="host-content-shell">
            <main role="main" class="host-main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="host-footer">
        <div class="host-footer-card">
            <div class="host-footer-inner">
                &copy; 2024 - Host Portal
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>