@model List<WebAdmin.MVC.Models.Rooms.RoomListItemVm>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Rooms";

    string currentSearch = Context.Request.Query["search"];
    string currentStatus = Context.Request.Query["status"];
}

<div class="container">

    <div class="card">

        <div class="card-head">

            <h2 class="card-title">Rooms</h2>

            <a class="btn btn-primary"
               asp-controller="Rooms"
               asp-action="Create">
                + Create Room
            </a>

        </div>


        <!-- SEARCH + FILTER -->

        <form method="get" class="toolbar">

            <input type="text"
                   name="search"
                   value="@currentSearch"
                   placeholder="Search room..."
                   class="form-control" />

            <select name="status" class="form-select">

                <option value="">All Status</option>

                <option value="Available" selected="@(currentStatus=="Available")">
                    Available
                </option>

                <option value="Occupied" selected="@(currentStatus=="Occupied")">
                    Occupied
                </option>

                <option value="Maintenance" selected="@(currentStatus=="Maintenance")">
                    Maintenance
                </option>

                <option value="Disabled" selected="@(currentStatus=="Disabled")">
                    Disabled
                </option>

            </select>

            <button type="submit" class="btn btn-secondary">
                Search
            </button>

        </form>


        <div class="table-wrap">

            <table class="table">

                <thead>
                    <tr>
                        <th>ROOM</th>
                        <th>BLOCK</th>
                        <th>FLOOR</th>
                        <th>PRICE</th>
                        <th>STATUS</th>
                        <th class="text-end">ACTIONS</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var r in Model)
                    {
                        string chipClass;
                        string statusText = r.Status?.ToUpper() ?? "UNKNOWN";

                        switch (statusText)
                        {
                            case "AVAILABLE":
                                chipClass = "success";
                                break;

                            case "OCCUPIED":
                                chipClass = "info";
                                break;

                            case "MAINTENANCE":
                                chipClass = "warning";
                                break;

                            case "DISABLED":
                                chipClass = "danger";
                                break;

                            default:
                                chipClass = "muted";
                                break;
                        }

                        <tr>

                            <td>@r.Name</td>
                            <td>@r.Block</td>
                            <td>@r.Floor</td>
                            <td>@r.Price.ToString("N0")</td>

                            <td>
                                <span class="chip @chipClass">
                                    @statusText
                                </span>
                            </td>

                            <td class="text-end">

                                <a class="link"
                                   asp-controller="Rooms"
                                   asp-action="Details"
                                   asp-route-id="@r.Id">
                                    Details
                                </a>

                                <a class="link"
                                   asp-controller="Rooms"
                                   asp-action="Edit"
                                   asp-route-id="@r.Id">
                                    Edit
                                </a>

                                <button class="link text-danger"
                                        onclick="confirmDelete(@r.Id,'@r.Name')">
                                    Delete
                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>


        <!-- PAGINATION -->

        <div class="pagination">

            <a asp-action="Index"
               asp-route-page="1"
               asp-route-search="@currentSearch"
               asp-route-status="@currentStatus"
               class="page-link">1</a>

            <a asp-action="Index"
               asp-route-page="2"
               asp-route-search="@currentSearch"
               asp-route-status="@currentStatus"
               class="page-link">2</a>

            <a asp-action="Index"
               asp-route-page="3"
               asp-route-search="@currentSearch"
               asp-route-status="@currentStatus"
               class="page-link">3</a>

        </div>


    </div>

</div>



<!-- DELETE MODAL -->

<div id="deleteModal" class="modal-overlay" style="display:none">

    <div class="modal-box">

        <h3>Delete Room</h3>

        <p id="deleteMessage"></p>

        <form id="deleteForm" method="post">

            @Html.AntiForgeryToken()

            <div class="modal-actions">

                <button type="button"
                        class="btn"
                        onclick="closeDelete()">
                    Cancel
                </button>

                <button type="submit"
                        class="btn btn-danger">
                    Delete
                </button>

            </div>

        </form>

    </div>

</div>



<script>

    function confirmDelete(id,name){

    document.getElementById("deleteMessage").innerText =
    "Are you sure you want to delete room: " + name + "?";

    document.getElementById("deleteForm").action =
    "/Rooms/Delete/" + id;

    document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDelete(){
    document.getElementById("deleteModal").style.display = "none";
    }

</script>