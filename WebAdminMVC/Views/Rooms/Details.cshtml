@model WebAdmin.MVC.Models.Rooms.RoomDetailsVm

@{
    Layout = "_Layout";
    ViewData["Title"] = "Room Details";
}

<div class="container">

    <div class="card pad-20">

        <div class="card-head">
            <div class="card-title">Room Details</div>

            <div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="link">Edit</a>
                <a asp-action="Index" class="link">Back</a>
            </div>
        </div>

        <div class="detail-grid">

            <div class="detail-item">
                <div class="muted">Room Code</div>
                <div class="user-email">@Model.RoomCode</div>
            </div>

            <div class="detail-item">
                <div class="muted">Room Name</div>
                <div class="user-email">@Model.RoomName</div>
            </div>

            <div class="detail-item">
                <div class="muted">Block</div>
                <div class="user-email">@Model.Block</div>
            </div>

            <div class="detail-item">
                <div class="muted">Floor</div>
                <div class="user-email">@Model.Floor</div>
            </div>

            <div class="detail-item">
                <div class="muted">Price</div>
                <div class="user-email">@Model.Price.ToString("N0") VND</div>
            </div>

            <div class="detail-item">
                <div class="muted">Status</div>

                @if (Model.Status == "Available")
                {
                    <span class="chip success">Available</span>
                }
                else
                {
                    <span class="chip danger">@Model.Status</span>
                }
            </div>

        </div>

    </div>

</div>