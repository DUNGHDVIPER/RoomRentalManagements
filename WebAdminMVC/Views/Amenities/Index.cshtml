@model List<WebAdmin.MVC.Models.Amenities.AmenityListItemVm>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Amenities";
}

<div class="amenity-page">

    <div class="amenity-card">

        <!-- HEADER -->
        <div class="amenity-header">

            <div class="header-left">
                <h2>Room Amenities</h2>
                <p>Manage all amenities available for rooms</p>
            </div>

            <div class="header-right">
                <a class="btn-add"
                   asp-controller="Amenities"
                   asp-action="Create">
                    Add Amenity
                </a>
            </div>

        </div>


        <!-- TABLE -->
        <div class="table-wrapper">

            <table class="amenity-table">

                <thead>
                    <tr>
                        <th>Amenity Name</th>
                        <th style="width:160px">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="empty-state">
                                <div class="empty-box">
                                    <p>No amenities found</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var a in Model)
                        {
                            <tr>

                                <td>
                                    <span class="amenity-chip">
                                        @a.AmenityName
                                    </span>
                                </td>

                                <td class="actions">

                                    <a class="btn-edit"
                                       asp-action="Edit"
                                       asp-route-id="@a.AmenityId">
                                        Edit
                                    </a>

                                    <button class="btn-delete"
                                            onclick="confirmDelete(@a.AmenityId,'@a.AmenityName')">
                                        Delete
                                    </button>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>



<!-- =========================
        DELETE MODAL
========================= -->

<div id="deleteModal" class="modal-overlay" style="display:none">

    <div class="modal-box">

        <h3>Delete Amenity</h3>

        <p>
            Are you sure you want to delete
            <b id="amenityName"></b> ?
        </p>

        <form id="deleteForm"
              asp-controller="Amenities"
              asp-action="Delete"
              method="post">

            <input type="hidden" name="id" id="deleteId" />

            <div class="modal-actions">

                <button type="button"
                        class="btn-cancel"
                        onclick="closeModal()">
                    Cancel
                </button>

                <button type="submit"
                        class="btn-danger">
                    Delete
                </button>

            </div>

        </form>

    </div>

</div>



<script>

    function confirmDelete(id,name)
    {
        document.getElementById("deleteId").value = id;
        document.getElementById("amenityName").innerText = name;

        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeModal()
    {
        document.getElementById("deleteModal").style.display = "none";
    }

    window.onclick = function(e)
    {
        const modal = document.getElementById("deleteModal");

        if(e.target === modal)
            modal.style.display = "none";
    }

</script>